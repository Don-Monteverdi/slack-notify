# slack-notify configuration
# Copy to ~/.config/slack-notify/.env and fill in your values.
# See README.md for setup instructions.

# ─── Required ───────────────────────────────────────────────────────────────

# Slack Bot Token (xoxb-...)
# Create at: https://api.slack.com/apps → OAuth & Permissions → Bot Token
# Required scopes: chat:write, channels:history, channels:read
SLACK_BOT_TOKEN=

# Channel ID to post to
# Find: Right-click channel in Slack → "View channel details" → scroll to bottom
SLACK_CHANNEL_ID=

# ─── Optional ───────────────────────────────────────────────────────────────

# Channel name (used in human-readable output, defaults to channel ID)
# SLACK_CHANNEL_NAME=general

# Workspace / Team ID
# SLACK_TEAM_ID=

# Webhook URL (alternative to Bot Token for simple posting)
# SLACK_WEBHOOK_URL=

# ─── Daemon Settings (only needed if using slack-daemon) ────────────────────

# Bot's own user ID — REQUIRED for daemon (to skip own messages)
# Find: Slack app → Basic Info → App Credentials, or call auth.test API
# SLACK_BOT_USER_ID=

# Claude binary path (auto-detected if on PATH)
# SLACK_NOTIFY_CLAUDE_BIN=/usr/local/bin/claude

# Project directory for daemon context (defaults to $PWD)
# SLACK_NOTIFY_PROJECT_DIR=/path/to/your/project

# Custom daemon prompt file (plain text)
# SLACK_NOTIFY_DAEMON_PROMPT=~/.config/slack-notify/daemon-prompt.txt

# Poll interval in seconds (default: 15)
# SLACK_NOTIFY_POLL_INTERVAL=15

# Max log lines before rotation (default: 1000)
# SLACK_NOTIFY_MAX_LOG_LINES=1000
