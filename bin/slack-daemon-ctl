#!/usr/bin/env bash
# slack-daemon-ctl — Control the Slack response daemon
#
# Usage:
#   slack-daemon-ctl start    # Start daemon in background
#   slack-daemon-ctl stop     # Stop daemon gracefully
#   slack-daemon-ctl restart  # Restart daemon
#   slack-daemon-ctl status   # Show running/stopped + PID
#   slack-daemon-ctl logs     # Tail last 50 lines
#   slack-daemon-ctl logs -f  # Follow logs

set -euo pipefail

# Resolve symlinks to find the real script directory
SELF="$0"
while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
DAEMON_SCRIPT="${SCRIPT_DIR}/slack-daemon"

# State / runtime directories (match daemon paths)
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/slack-notify"
RUN_DIR="${XDG_RUNTIME_DIR:-/tmp}/slack-notify"
PID_FILE="${RUN_DIR}/daemon.pid"
LOG_FILE="${STATE_DIR}/daemon.log"

is_running() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

cmd_start() {
    if is_running; then
        echo "Daemon already running (PID $(cat "$PID_FILE"))"
        return 0
    fi
    mkdir -p "$STATE_DIR" "$RUN_DIR"
    nohup bash "$DAEMON_SCRIPT" >> "$LOG_FILE" 2>&1 &
    # PID is written by the daemon itself, but save the nohup PID as fallback
    sleep 1
    if is_running; then
        echo "Daemon started (PID $(cat "$PID_FILE"))"
    else
        echo "ERROR: Daemon failed to start. Check logs: $LOG_FILE" >&2
        exit 1
    fi
}

cmd_stop() {
    if ! is_running; then
        echo "Daemon not running"
        rm -f "$PID_FILE"
        return 0
    fi
    local PID
    PID=$(cat "$PID_FILE")
    kill "$PID" 2>/dev/null
    # Wait up to 5 seconds for clean shutdown
    for _ in 1 2 3 4 5; do
        if ! kill -0 "$PID" 2>/dev/null; then
            echo "Daemon stopped (was PID $PID)"
            rm -f "$PID_FILE"
            return 0
        fi
        sleep 1
    done
    # Force kill
    kill -9 "$PID" 2>/dev/null || true
    rm -f "$PID_FILE"
    echo "Daemon force-stopped (was PID $PID)"
}

cmd_status() {
    if is_running; then
        local PID
        PID=$(cat "$PID_FILE")
        local UPTIME
        UPTIME=$(ps -o etime= -p "$PID" 2>/dev/null | xargs)
        echo "Running (PID $PID, uptime: ${UPTIME:-unknown})"
    else
        echo "Stopped"
        rm -f "$PID_FILE"
    fi
}

cmd_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "No log file yet: $LOG_FILE"
        return 0
    fi
    if [ "${1:-}" = "-f" ]; then
        tail -f "$LOG_FILE"
    else
        tail -n 50 "$LOG_FILE"
    fi
}

# ── Main ────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_stop; sleep 1; cmd_start ;;
    status)  cmd_status ;;
    logs)    cmd_logs "${2:-}" ;;
    *)
        echo "Usage: slack-daemon-ctl {start|stop|restart|status|logs [-f]}"
        exit 1
        ;;
esac
